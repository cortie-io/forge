[Unit]
Description=Sikdorak Express API
After=network.target postgresql.service
Wants=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/sikdorak
Environment=NODE_ENV=production
Environment=PORT=3100
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=3
KillSignal=SIGTERM
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
